{
	"name": "share2fedi",
	"version": "4.0.0-alpha.3",
	"description": "Instance-agnostic share page for the Fediverse.",
	"license": "AGPL-3.0-only",
	"author": "Nikita Karamov <me@kytta.dev>",
	"homepage": "https://s2f.kytta.dev/",
	"repository": {
		"type": "git",
		"url": "https://github.com/kytta/share2fedi.git"
	},
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro build",
		"build:icons": "bash ./script/build-icons",
		"preview": "astro preview",
		"check": "pnpm run /^check:/",
		"check:astro": "astro check",
		"check:eslint": "eslint .",
		"check:prettier": "prettier --check --plugin=prettier-plugin-astro .",
		"check:stylelint": "stylelint **/*.css",
		"fix": "pnpm fix:prettier . && pnpm fix:eslint .",
		"fix:eslint": "eslint --fix",
		"fix:prettier": "prettier --write --ignore-unknown --plugin=prettier-plugin-astro",
		"fix:stylelint": "stylelint --fix",
		"test": "pnpm run check",
		"prepare": "husky || true"
	},
	"browserslist": "> 0.5%, last 4 versions, last 2.5 years, Firefox ESR, not dead",
	"dependencies": {
		"@astrojs/node": "^9.5.5",
		"@nanostores/persistent": "^1.0.0",
		"astro": "~5.18.0",
		"nanostores": "^1.0.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.6",
		"@eslint/js": "^9.34.0",
		"@types/node": "^22.18.0",
		"@typescript-eslint/parser": "^8.41.0",
		"browserslist": "^4.25.4",
		"eslint": "^9.34.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-astro": "^1.3.1",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-unicorn": "^61.0.0",
		"globals": "^16.3.0",
		"husky": "^9.1.7",
		"lightningcss": "^1.30.1",
		"nano-staged": "^0.9.0",
		"prettier": "^3.6.2",
		"prettier-plugin-astro": "^0.14.1",
		"sharp": "^0.34.5",
		"stylelint": "^17.0.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-standard": "^40.0.0",
		"svgo": "^4.0.1",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.41.0"
	},
	"nano-staged": {
		"*": "pnpm run fix:prettier",
		"*.{astro,js,ts}": "pnpm run fix:eslint",
		"*.css": "pnpm run fix:stylelint",
		"assets/*.{png,svg}": "pnpm run build:icons"
	},
	"prettier": {
		"singleAttributePerLine": true
	},
	"engines": {
		"node": "^18.17.1 || ^20.3.0 || ^22.0.0"
	}
}
